{
  "branches": [
    "main",
    {"name": "*", "prerelease": "alpha"},
    {"name": "*/*", "prerelease": "alpha"}
  ],
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    ["@semantic-release/github", {
      "assets": [
        {"path": "backend-image.tar", "label": "Backend Docker Image"},
        {"path": "frontend-image.tar", "label": "Frontend Docker Image"},
        {"path": "bom.json", "label": "Backend SBOM"},
        {"path": "frontend-bom.json", "label": "Frontend SBOM"}
      ]
    }]
  ]
}
